# RatesAssist environment configuration
# Copy this to .env.local and fill in real values

# === REQUIRED for live LLM ===
ANTHROPIC_API_KEY=sk-ant-...

# === Optional: AU region preference (defaults to global if not set) ===
# ANTHROPIC_BASE_URL=

# === Mapping providers (premium tiers — graceful fallback when unset) ===
# Mapbox (free 50k loads/mo, satellite + streets + hybrid + outdoors).
# Get a token at https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=

# Nearmap (premium aerial + AI change detection).
# Without this token the app uses Esri World Imagery as the aerial layer.
NEXT_PUBLIC_NEARMAP_API_KEY=

# MapTiler (alternative to Mapbox, free 100k tile loads/mo)
NEXT_PUBLIC_MAPTILER_KEY=

# === Public APIs (no key required) ===
# DMIRS tenement WFS + Landgate cadastre WMS default to the WA SLIP public
# endpoints baked into @ratesassist/spatial and lib/basemaps. Leave blank to use
# the built-in defaults; set a value to override. The Landgate override is read
# client-side, so it carries the NEXT_PUBLIC_ prefix (matching the map keys above).
DMIRS_WFS_BASE=
NEXT_PUBLIC_LANDGATE_SLIP_WMS=
ABN_LOOKUP_BASE=https://abr.business.gov.au/json
ABN_LOOKUP_GUID=

# === Demo mode ===
# LLM mode is auto by default: live when ANTHROPIC_API_KEY is a valid sk-ant-…
# key, deterministic mock otherwise. Override: MOCK_LLM=mock forces the mock
# even when a key is present (offline demos / reproducible walkthroughs);
# MOCK_LLM=auto (or unset) uses the key-based default.
MOCK_LLM=auto

# === Demo autologin (production escape hatch — MoU §7(c)) ===
# RA_DEMO_AUTOLOGIN=1 allows the dev autologin to operate in production for
# the council-CFO pilot walkthrough. It ONLY works alongside
# RA_DEMO_AUTOLOGIN_EXPIRES — an ISO date/datetime after which autologin is
# refused regardless of the flag (the risk register's "disable by end of
# pilot week 1" control, enforced in code). Leave both unset outside demos.
RA_DEMO_AUTOLOGIN=
RA_DEMO_AUTOLOGIN_EXPIRES=

# === Document integrity (JD-2 — PDF verification) ===
# Dedicated HMAC key for the cryptographic integrity ref embedded in every
# generated evidence/notice PDF and re-derived by POST /api/verify/pack.
# REQUIRED in production (>=16 chars); a dev fallback is used otherwise.
# Keep this SEPARATE from RA_AUTH_SECRET so PDF integrity and session signing
# never share key material.
RA_PDF_SIGNING_SECRET=

# === Rate-limit client-IP derivation (RA-L3-02) ===
# Number of TRUSTED reverse-proxy hops in front of the app. The real client IP
# is taken Nth-from-right in X-Forwarded-For (the trusted proxy appends the IP
# it observed). Default 1 = a single ALB / Vercel edge. Set to 2 if a CDN
# (CloudFront) sits in front of the ALB. Only consulted when RA_TRUSTED_PROXY=1.
RA_TRUSTED_PROXY_HOPS=1
