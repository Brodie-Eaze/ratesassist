# Anthropic key — when unset/invalid, the chat falls back to deterministic mock mode.
ANTHROPIC_API_KEY=

# ABN Lookup (ATO) — leave guid blank for honest mock results in dev.
ABN_LOOKUP_BASE=https://abr.business.gov.au/json
ABN_LOOKUP_GUID=

# ===== MCP adapter wiring (Phase 1B) =====
# Override the path to the @ratesassist/adapter-demo MCP server bin.
# Default: monorepo-relative ../../packages/adapter-demo/dist/server.js
RA_MCP_ADAPTER_PATH=

# Per-tool-call timeout for MCP requests, milliseconds. Default 5000.
RA_MCP_TOOL_TIMEOUT_MS=5000
