# =============================================================================
# RatesAssist apps/web — environment variable reference
# Every variable is OPTIONAL unless flagged REQUIRED. Defaults make the app
# boot in deterministic mock mode so a fresh clone runs without secrets.
# =============================================================================

# ----- Anthropic (chat / tool-loop) ------------------------------------------

# Live tool-loop chat. When unset/invalid, /api/chat falls back to a
# deterministic mock that still exercises the MCP tool surface.
# Gates: live LLM responses.
ANTHROPIC_API_KEY=

# ----- Tool transport (Phase 1B) ---------------------------------------------

# How apps/web talks to the adapter:
#   mcp     — spawn @ratesassist/adapter-demo as a child process over stdio
#             (default; required when you want to exercise the real MCP wire).
#   inproc  — import the dispatcher and call it in-process. Required on
#             Vercel and any other serverless target where long-lived child
#             processes are not viable.
# Auto-set to "inproc" when VERCEL=1.
# Gates: which transport mcp-client.ts uses.
RA_TOOL_TRANSPORT=

# Override the path to the bundled adapter-demo MCP server entrypoint.
# Default (mcp transport): ../../packages/adapter-demo/dist/server.js,
# resolved against the monorepo root. Path is validated at module load —
# must live inside the monorepo and end in /dist/server.js.
# Gates: alternative adapter binaries (e.g., a TechOne adapter dist).
RA_MCP_ADAPTER_PATH=

# Per-tool-call timeout, milliseconds. Default 5000.
# Gates: how long mcp-client waits before returning {code:"timeout"}.
RA_MCP_TOOL_TIMEOUT_MS=5000

# ----- ABN Lookup (ATO ABR) --------------------------------------------------

# Override the ABR base URL. Default https://abr.business.gov.au/json.
# Gates: ABN identity tools.
ABN_LOOKUP_BASE=https://abr.business.gov.au/json

# Production ABN Lookup GUID. Absent => mock results for known ABNs and an
# explicit error for unknown ones. Required for live identity verification.
# Gates: real ABR queries (vs. honest mock).
ABN_LOOKUP_GUID=

# ----- DMIRS / SLIP spatial --------------------------------------------------

# Override the DMIRS WFS endpoint. Default lives in @ratesassist/spatial.
# Validated against an allowlist at module load — refusing arbitrary endpoints
# prevents SSRF via env injection.
# Gates: tenement queries hitting WA SLIP.
DMIRS_WFS_BASE=

# ----- Runtime mode ----------------------------------------------------------

# When NODE_ENV=production, the ABN client locks into strict mode (no
# silent mock fallbacks). Required for any non-demo deploy.
NODE_ENV=development

# ----- Smoke harness only ----------------------------------------------------

# Port used by scripts/smoke.ts. Not consumed by the app at runtime.
RA_SMOKE_PORT=3100
