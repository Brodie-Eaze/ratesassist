# =============================================================================
# RatesAssist apps/web — environment variable reference
# Every variable is OPTIONAL unless flagged REQUIRED. Defaults make the app
# boot in deterministic mock mode so a fresh clone runs without secrets.
# =============================================================================

# ----- Anthropic (chat / tool-loop) ------------------------------------------

# Live tool-loop chat. When unset/invalid, /api/chat falls back to a
# deterministic mock that still exercises the MCP tool surface.
# Gates: live LLM responses.
ANTHROPIC_API_KEY=

# Anthropic API base URL. Defaults to https://api.anthropic.com.au (AU
# region). In production, the resolved value MUST be either
# https://api.anthropic.com.au or a *.amazonaws.com(.au) Bedrock Sydney
# endpoint — non-AU values throw at module load (SEC-007).
# In development, non-AU values are allowed but logged with a warning.
ANTHROPIC_BASE_URL=

# Disable PII scrubbing on outbound chat input (SEC-016). Dev/test only —
# never set in production. When unset, AU ABNs, AU phone numbers, and email
# addresses are redacted before forwarding to Anthropic.
RA_DISABLE_PII_SCRUB=

# ----- Security middleware ---------------------------------------------------

# Comma-separated list of /api/* path prefixes exempt from the
# Origin/CSRF check on POST/PUT/PATCH/DELETE (SEC-014). Leave unset by
# default — every API route should require Origin matching.
RA_CSRF_EXEMPT_PATHS=

# Trust X-Forwarded-For for client-IP extraction (SEC-008). Set to "1"
# only when running behind a known reverse proxy that rewrites XFF.
# On Vercel this is implicit (VERCEL=1). Elsewhere, leaving this unset
# means we fall back to the raw connection IP, which is spoofing-resistant.
RA_TRUSTED_PROXY=

# ----- Tool transport (Phase 1B) ---------------------------------------------

# How apps/web talks to the adapter:
#   mcp     — spawn @ratesassist/adapter-demo as a child process over stdio
#             (default; required when you want to exercise the real MCP wire).
#   inproc  — import the dispatcher and call it in-process. Required on
#             Vercel and any other serverless target where long-lived child
#             processes are not viable.
# Auto-set to "inproc" when VERCEL=1.
# Gates: which transport mcp-client.ts uses.
RA_TOOL_TRANSPORT=

# Override the path to the bundled adapter-demo MCP server entrypoint.
# Default (mcp transport): ../../packages/adapter-demo/dist/server.js,
# resolved against the monorepo root. Path is validated at module load —
# must live inside the monorepo and end in /dist/server.js.
# Gates: alternative adapter binaries (e.g., a TechOne adapter dist).
RA_MCP_ADAPTER_PATH=

# Per-tool-call timeout, milliseconds. Default 5000.
# Gates: how long mcp-client waits before returning {code:"timeout"}.
RA_MCP_TOOL_TIMEOUT_MS=5000

# ----- ABN Lookup (ATO ABR) --------------------------------------------------

# Override the ABR base URL. Default https://abr.business.gov.au/json.
# Gates: ABN identity tools.
ABN_LOOKUP_BASE=https://abr.business.gov.au/json

# Production ABN Lookup GUID. Absent => mock results for known ABNs and an
# explicit error for unknown ones. Required for live identity verification.
# Gates: real ABR queries (vs. honest mock).
ABN_LOOKUP_GUID=

# ----- DMIRS / SLIP spatial --------------------------------------------------

# Override the DMIRS WFS endpoint. Default lives in @ratesassist/spatial.
# Validated against an allowlist at module load — refusing arbitrary endpoints
# prevents SSRF via env injection.
# Gates: tenement queries hitting WA SLIP.
DMIRS_WFS_BASE=

# ----- Runtime mode ----------------------------------------------------------

# When NODE_ENV=production, the ABN client locks into strict mode (no
# silent mock fallbacks). Required for any non-demo deploy.
NODE_ENV=development

# ----- Auth & SSO (Round 4) --------------------------------------------------

# REQUIRED in production. HMAC secret used to sign and verify session cookies.
# Must be >=16 characters. The app refuses to start in production without it.
# In development, a deterministic dev-only secret is used if unset.
# Gates: all signed sessions (login, /api/me, every /api/* check).
RA_AUTH_SECRET=

# Optional. Dev/demo only — when set, every request without a valid session
# gets one auto-minted from this config. Accepts:
#   - "default" / "1" / "true": demo officer at TPS
#   - JSON object: {"tenantId":"TPS","roles":["rates_officer"], ...}
# Ignored entirely when NODE_ENV=production.
RA_DEV_AUTOLOGIN_SESSION=

# ----- WorkOS SSO (Round 5 — live in production) -----------------------------
#
# RatesAssist uses WorkOS as the SSO front-door. WorkOS is free for the
# first 1M monthly users; a council deployment costs us nothing on auth.
# Each council connects ONE identity provider (almost always Microsoft
# Entra ID) to a WorkOS connection; the connection id is configured in
# the WorkOS dashboard, not here.
#
# When ANY of these three are unset:
#   - /api/auth/sso/start  →  redirects to /login?error=sso_not_configured
#   - /api/auth/callback   →  501 in production (dev: redirect to /login)
# This is intentional — we refuse to redirect users into a broken handshake.

# WorkOS client id. Find it at https://dashboard.workos.com → API Keys.
# Shape: client_<22-char-base32>. Example (redacted):
#   RA_SSO_CLIENT_ID=client_01H4F00BAR0000000000000000
RA_SSO_CLIENT_ID=

# WorkOS API key (a.k.a. client secret). Same dashboard page.
# Shape: sk_test_<...> or sk_live_<...>. NEVER commit a real value here.
RA_SSO_CLIENT_SECRET=

# Fully-qualified callback URL. Must EXACTLY match the redirect URI
# configured in the WorkOS dashboard for this connection.
# Example: https://app.ratesassist.com.au/api/auth/callback
RA_SSO_REDIRECT_URI=

# IdP hint passed to WorkOS. Defaults to MicrosoftOAuth (Entra ID) —
# correct for every Australian council we've sized so far. Override with
# GoogleOAuth, OktaSAML, etc. for non-Microsoft tenants.
RA_SSO_PROVIDER=MicrosoftOAuth

# Optional. Override base endpoints — only needed when staging against the
# WorkOS staging environment.
RA_SSO_AUTHORIZE_URL=
RA_SSO_TOKEN_URL=

# Default tenant for users whose email domain isn't recognised by the
# DOMAIN_TO_TENANT map in apps/web/lib/workos.ts. Useful for the marketing
# / demo deployment where any signed-in user lands in TPS. Leave unset for
# real council deployments — unknown domains should bounce back to /login.
RA_SSO_DEFAULT_TENANT=TPS

# Comma-separated allow-list of emails that receive the `platform_admin`
# role on sign-in. RatesAssist staff only. Example:
#   RA_PLATFORM_ADMIN_EMAILS=brodie@ratesassist.com.au,ops@ratesassist.com.au
RA_PLATFORM_ADMIN_EMAILS=

# ----- Persistence (Phase 2b) ------------------------------------------------

# When set, /api/recovery/* and the demo mutation flows read/write through
# @ratesassist/db instead of the in-process arrays. The cached
# EvaluationContext is rebuilt from DB rows on each invalidation.
#   - Unset or "true" in development: DB-wired path active.
#   - Unset or "false" in production: in-memory fallback (until a real DB is
#     provisioned). Override with "true" once your DATABASE_URL points at a
#     production-class Postgres.
RA_USE_DB=

# DB connection string. Two forms accepted:
#   - pglite://memory (or unset): the package boots an in-memory WASM
#     Postgres (@electric-sql/pglite). State is lost on process restart.
#     Suitable for dev, vitest integration tests, the smoke harness.
#   - postgres://user:pass@host:port/db — real node-postgres pool. Required
#     for production deployments where mutations must survive restarts.
DATABASE_URL=

# ----- Smoke harness only ----------------------------------------------------

# Port used by scripts/smoke.ts. Not consumed by the app at runtime.
RA_SMOKE_PORT=3100
