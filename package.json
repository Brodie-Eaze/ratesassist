{
  "name": "ratesassist",
  "version": "0.2.0",
  "private": true,
  "description": "RatesAssist — vertical AI for Australian council rates departments. Production monorepo.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "typecheck": "npm run typecheck --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:adapter-demo": "npm run dev --workspace=packages/adapter-demo",
    "ship-check": "bash scripts/ship-check.sh",
    "smoke": "tsx scripts/smoke.ts"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  }
}
