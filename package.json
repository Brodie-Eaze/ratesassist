{
  "name": "ratesassist",
  "version": "0.2.0",
  "private": true,
  "description": "RatesAssist — vertical AI for Australian council rates departments. Production monorepo.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "typecheck": "npm run typecheck --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:adapter-demo": "npm run dev --workspace=packages/adapter-demo"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.9.0"
  }
}
